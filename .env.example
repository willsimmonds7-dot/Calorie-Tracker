# Copy this file to ".env" and fill in the values.

# OpenAI key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Supabase Postgres connection string.
# Supabase dashboard -> Project Settings -> Database -> Connection string -> URI
# (replace [YOUR-PASSWORD] with your database password)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres

# Optional. Defaults shown.
OPENAI_MODEL=gpt-4o
PORT=3000

# Time zone for the "today" totals (DST-aware). Default: Europe/Amsterdam.
# Use any IANA name, e.g. America/New_York, Europe/London.
TZ_NAME=Europe/Amsterdam

# Set to "disable" only when using a plain local Postgres without SSL.
# Leave unset for Supabase (SSL is used by default).
# PGSSL=disable
